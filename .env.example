# =============================================================================
# Manual-Betting +EV Picks Platform (betting-ai) — environment template
# Copy to .env and fill in values. NEVER commit .env.
# =============================================================================

APP_ENV=local
LOG_LEVEL=INFO

# --- Infrastructure -----------------------------------------------------------
# Host ports 5433/6380 — 5432/6379 are occupied by the weatherbot project.
# These URLs are for HOST-run processes (alembic, scripts/, pytest, the dev
# server). The compose `app` service OVERRIDES them with in-container service
# hostnames (postgres:5432 / redis:6379) in its environment block — do NOT
# change these to postgres:/redis: or every host-run tool breaks.
DATABASE_URL=postgresql+asyncpg://betting_ai:betting_ai@localhost:5433/betting_ai
REDIS_URL=redis://localhost:6380/0

# Postgres superuser password for the compose stack (docker-compose.yml
# interpolates ${POSTGRES_PASSWORD:-betting_ai}). Local dev: leave unset.
# VPS: set a real value BEFORE first boot — pgdata is initialized with the
# first password; changing it later requires ALTER USER inside postgres.
#POSTGRES_PASSWORD=

# VPS ONLY — uncomment so plain `docker compose up -d` includes the app
# service (it is behind the "prod" profile). Leave commented on the Mac,
# where the app runs on the host and `up -d` should start postgres/redis only.
#COMPOSE_PROFILES=prod

# Host interface for the compose app port. Default = SSH tunnel / local
# reverse proxy only. To open from an external IP, set APP_HOST_BIND=0.0.0.0
# ONLY after enabling DASHBOARD_AUTH_* below. Postgres and Redis stay
# loopback-only in docker-compose.yml and must never be exposed publicly.
APP_HOST_BIND=127.0.0.1

# --- SAFETY FLAGS (decision-support only) --------------------------------------
# This platform recommends picks; the user reviews and places bets manually.
# There is NO auto-betting capability by design: no code path can place a bet,
# and app/config.py hard-fails at startup if these defaults are tampered with.
PICKS_ONLY=true
MANUAL_BETTING_ONLY=true
AUTO_BETTING=false
BET_EXECUTION_ENABLED=false
READ_ONLY_MARKET_DATA=true
PAPER_TRADING=false

# --- Pick gates ----------------------------------------------------------------
MIN_EDGE=0.03
MIN_EV=0.01
MIN_CONFIDENCE=0.60
MAX_ODDS_AGE_SECONDS=300
MIN_LIQUIDITY=0

# --- Recommended stake sizing (informational only) ------------------------------
BANKROLL_BASE=1000
FRACTIONAL_KELLY=0.25
MAX_RECOMMENDED_STAKE_PERCENT=0.02
MAX_DAILY_EXPOSURE_PERCENT=0.05

# --- Alerts ---------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_URL=
# How long an UNCHANGED market state stays suppressed (seconds; default 7
# days). A price move re-alerts immediately regardless — the dedupe key
# includes the odds. Failed deliveries release the claim and retry next cycle.
ALERT_DEDUPE_TTL_SECONDS=604800

# --- Dashboard auth -----------------------------------------------------------------
# ENABLED by default in this template. Two ways to set the single admin login:
#   • EASIEST — leave HASH/SECRET below BLANK: on first launch the app shows a
#     one-time /setup screen to create the password and stores it in the DB.
#   • Or pre-provision here (hand-managed hosts): set BOTH or NEITHER, never one.
# config.py defaults auth OFF only when no .env is present (loopback dev); auth
# is ALWAYS required before APP_HOST_BIND=0.0.0.0 or any public reverse proxy.
# SECURITY: on a public bind the first visitor claims the /setup password — set
# it over your SSH tunnel (loopback) BEFORE exposing the port. The plaintext is
# NEVER stored, only the salted hash (in the DB / .env, gitignored, never in
# this repo).
#   hash:   uv run python -c "from app.api.auth import hash_password; print(hash_password('YOUR_PASSWORD'))"
#   secret: uv run python -c "import secrets; print(secrets.token_urlsafe(48))"
# Wrap the hash in single quotes in .env because Docker Compose interpolates
# unquoted $ characters.
# /health stays public (compose healthcheck / external watchdog).
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_AUTH_USERNAME=admin
DASHBOARD_AUTH_PASSWORD_HASH=
DASHBOARD_SESSION_SECRET=
# DASHBOARD_SESSION_TTL_SECONDS=43200

# --- Pick strategy -----------------------------------------------------------------
# "value" (default): sharp-vs-soft line shopping — BACKTESTED positive holdout
#   CLV (docs/backtesting/value-findings.md). "model": Dixon-Coles screens only.
# Defaults = v4 train-chosen optimum over 7 devig methods with the 1.60
# odds floor (differential-margin devig, edge >= 0.03): holdout n=61,
# ROI +21.1%, incremental CLV +0.106 > 2SE; shin/0.03 indistinguishable.
# Volume tier: VALUE_MIN_EDGE=0.015 (v2 holdout n=379, ROI +2.5%, CLV +0.019).
PICK_STRATEGY=value
VALUE_MIN_EDGE=0.03
# Volume tier floor: edges in [VALUE_VOLUME_MIN_EDGE, VALUE_MIN_EDGE) persist
# as tier='volume' — no alert, no daily-exposure reservation, CLV-tracked
# only (v2 holdout n=379, CLV +0.019). Must be <= VALUE_MIN_EDGE; set EQUAL
# to disable the volume tier.
VALUE_VOLUME_MIN_EDGE=0.015
# Floor on candidate odds = the VALIDATED floor (1.30). A 2026-06-18 held-out
# floor sweep showed 1.60->1.30 adds ~1 pick over two seasons (ROI/CLV
# unchanged) and below 1.30 only admits the noisy short-odds region; raise to
# be more conservative.
VALUE_MIN_ODDS=1.30
VALUE_DEVIG=differential_margin_weighting
# ML value filter (meta-labeling; docs/research/ml-value-filter.md, ADOPT
# 2026-06-12: holdout n=396, ROI +12.0%, incCLV_max +0.0357 ± 0.0075 2SE).
# false (default): scores annotate picks only. true: premium picks scoring
# below the manifest operating point demote to the volume (shadow) tier.
# Artifacts (manifest+model) are NOT in git — see docs/deployment/.
VALUE_ML_FILTER=false
VALUE_ML_MODEL_DIR=data/ml
# Manifest/model filenames inside VALUE_ML_MODEL_DIR. Defaults = the v1
# ADOPT artifacts. The v2 retrain (docs/research/premium-tier-v2.md) is a
# SHADOW-CANDIDATE (verdict CANDIDATE — 2425+2526 are a SPENT holdout, so
# its binding verdict is live shadow CLV + the fresh 2627 season): to score
# it live for ANNOTATION ONLY set the three lines below. Demotion never
# happens on a shadow manifest, even with VALUE_ML_FILTER=true.
#VALUE_ML_MANIFEST_FILENAME=value_filter_manifest_v2.json
#VALUE_ML_MODEL_FILENAME=value_filter_model_v2.txt
#VALUE_ML_MANIFEST_ALLOW_SHADOW=true
# Premium-tier adjustment knobs (2026-06 strategy research) — ALL OFF by
# default (empty = exactly the validated behavior above). Do NOT enable
# without nested season-blocked walk-forward evidence within seasons <=2324
# or a never-consulted fresh domain — 2425+2526 are a SPENT holdout
# (docs/backtesting/value-findings.md, .claude/memory/decisions.md).
# Per-market PREMIUM min-edge overrides, csv "market_key:edge" (keys = the
# line-qualified market, e.g. 1x2 / over_under_2_5 / asian_handicap_-1_5,
# or a family: h2h / totals). Example: 1x2:0.04,over_under_2_5:0.035
VALUE_MIN_EDGE_PER_MARKET=
# Inclusive RAW-odds bands, csv "lo-hi" (e.g. 1.8-2.6,3.0-4.2). Empty = only
# the VALUE_MIN_ODDS floor. Which bands are soft must be LEARNED, not assumed.
VALUE_ODDS_BANDS=
# Per-market minimum distinct bookmakers, csv "market_key:count" (e.g.
# over_under_1_5:5) — thin-liquidity skip for new lines/divisions.
VALUE_MIN_BOOKS_PER_MARKET=
# Optional drawdown-constrained staking (set BOTH or NEITHER; stakes stay
# informational only): Kelly multiplier becomes min(FRACTIONAL_KELLY, λ*)
# with Pr(drawdown > STAKE_MAX_DRAWDOWN) <= STAKE_MAX_DRAWDOWN_PROBABILITY
# (Busseti-Boyd 2016 single-bet form — app/risk/staking.py). Phase-6 call.
#STAKE_MAX_DRAWDOWN=0.5
#STAKE_MAX_DRAWDOWN_PROBABILITY=0.1

# --- Odds / market data (READ-ONLY access only) ----------------------------------
# Free-first ingestion (see docs/research/free-odds-sources.md, ADR-0012).
# ODDS_SOURCE: "oddsportal" (default, FREE — OddsHarvester scrapes
# oddsportal.com, no key) or "odds_api" (The Odds API, needs keys below).
ODDS_SOURCE=oddsportal
# Slugs must be OddsHarvester league keys (oddsharvester.utils.
# sport_league_constants + our register_extra_leagues additions), or the
# sentinel "all" = NO league filter: dated daily pages covering every league
# (requires ODDSPORTAL_DAYS_AHEAD; cycle time scales with the day's slate).
# Off-season leagues simply yield no events.
ODDSPORTAL_FOOTBALL_LEAGUES=all
# Devig-sound markets only — the loader rejects push-bearing handicap keys
# by design. CYCLE-TIME BUDGET: with leagues=all every key costs one browser
# tab per match on a 100-300+ match daily page (~73s/match measured at 18
# tabs) — config enforces a max of 4 keys per sport when "all" is set; the
# full devig-sound families (documented in app/config.py comments) are for
# scoped-league configs only.
ODDSPORTAL_FOOTBALL_MARKETS=1x2,over_under_2_5,btts,double_chance
# Basketball club competitions (OddsHarvester has no national-team events
# like EuroBasket). "home_away" = moneyline. "all" = worldwide daily page
# (off-season simply yields nothing); empty leagues = basketball off.
ODDSPORTAL_BASKETBALL_LEAGUES=all
ODDSPORTAL_BASKETBALL_MARKETS=home_away,over_under_games_220_5,over_under_games_225_5,over_under_games_230_5
# Tennis is VISIBILITY-ONLY / UNVALIDATED (mints NO picks/alerts, scheduler+
# pipeline-enforced). Default = in-season atp-/wta- slugs (SEASONAL — rotate
# as the tour moves grass->hard->clay); empty = tennis off. Markets kept light
# (ML + the near-universal over/under 2.5 sets); the loader also supports
# over_under_games_* and half-line asian_handicap_*_sets/_games in .env.
ODDSPORTAL_TENNIS_LEAGUES=atp-halle,atp-london,atp-eastbourne,atp-mallorca,atp-wimbledon,wta-berlin,wta-birmingham,wta-eastbourne,wta-bad-homburg,wta-wimbledon
ODDSPORTAL_TENNIS_MARKETS=match_winner,over_under_sets_2_5
# American football / NFL is ALSO VISIBILITY-ONLY / UNVALIDATED (mints NO
# picks/alerts). Its free Pinnacle close is forward-captured via arcadia
# (sport-id 15, in ARCADIA_SPORTS below) — the prerequisite for ever
# CLV-grading NFL picks. Default leagues="nfl" (whole league); off-season the
# dated scrape yields no events. Slugs: nfl,ncaa. Empty = NFL off. home_away
# (moneyline) keeps the visibility scrape light.
ODDSPORTAL_NFL_LEAGUES=nfl
ODDSPORTAL_NFL_MARKETS=home_away
# OddsHarvester pacing (human-like; never anti-bot bypassing). Concurrency =
# parallel match pages (3 is human-realistic), request_delay jittered upstream.
# Locale pairs with the loader's forced UTC timezone (London -> en-GB).
ODDSPORTAL_CONCURRENCY=3
ODDSPORTAL_REQUEST_DELAY=1.0
ODDSPORTAL_LOCALE=en-GB
FOOTBALLDATA_LEAGUE_CODES=E0
FOOTBALLDATA_SEASONS=2425,2526
# Set to an in-season non-European code (BRA/ARG/USA/MEX/JPN/CHN) to train
# Dixon-Coles on that league instead of the European seasons. Empty = European.
FOOTBALLDATA_NEW_LEAGUE_CODE=
FOOTBALL_TOTALS_LINE=2.5
MODEL_CONFIDENCE=0.65

# The Odds API key is OPTIONAL (only for ODDS_SOURCE=odds_api); rotation
# supports ODDS_API_KEY_1..3.
ODDS_API_KEY=
ODDS_API_KEY_1=
ODDS_API_KEY_2=
ODDS_API_KEY_3=

# Pinnacle arcadia sharp-line archive (READ-ONLY, ON by default).
# Clean-room GET-only capture of Pinnacle's PUBLIC guest JSON API — the free
# live-Pinnacle sharp anchor (ADR-0013). Runs ALONGSIDE ODDS_SOURCE; never
# replaces it, mints NO picks. Captured closes land under the isolated
# `pinnacle_<sport>` warehouse namespace. ToS-grey + endpoint-fragile (treat
# scrape gaps as expected). The guest key is OPTIONAL (the endpoints used
# require none) and is NOT an account credential — leave empty unless Pinnacle
# starts requiring it. Set false to disable capture.
ARCADIA_ENABLED=true
ARCADIA_BASE_URL=https://guest.api.arcadia.pinnacle.com/0.1
ARCADIA_GUEST_KEY=
ARCADIA_SPORTS=soccer,tennis,basketball,american_football
ARCADIA_HORIZON_HOURS=72
ARCADIA_POLL_INTERVAL_SECONDS=120
# Optional Arcadia/Pinnacle outbound proxy rotation. Keep real values in .env
# only; never commit proxy credentials. Format:
# ARCADIA_PROXY_URLS=http://user:pass@host:port,http://user:pass@host:port
ARCADIA_PROXY_URLS=
# Attach the STRICT cross-source match's Pinnacle ARCHIVE close to picks at
# settlement so incremental CLV anchors on a real sharp close (app/resolution,
# ADR-0013). OFF by default — it changes anchor_type/CLV for matched picks;
# enable only with ARCADIA_ENABLED=true and after validating the match rate.
CLV_USE_PINNACLE_ARCHIVE=false

# Betfair: READ-ONLY market data credentials only — never order placement.
BETFAIR_APP_KEY=
BETFAIR_READ_ONLY_USERNAME=
BETFAIR_READ_ONLY_PASSWORD=

# NOTE: API-Football is SUSPENDED — do not add API_FOOTBALL_KEY; use
# football-data.co.uk / Understat / stats.nba.com fallbacks instead.
